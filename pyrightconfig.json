{
  "venvPath": ".",
  "venv": "venv",
  "pythonVersion": "3.11",
  "typeCheckingMode": "basic",
  "include": [
    "app",
    "scripts",
    "tests"
  ],
  "exclude": [
    "Test_UI",
    "venv",
    ".venv",
    "build",
    "dist",
    "**/__pycache__"
  ],
  "reportMissingModuleSource": "none",
  "reportUnnecessaryIsInstance": "error"
}
